# Port for server to listen on
PORT=5000

# MongoDB Connection URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/sportnest?retryWrites=true&w=majority

# JWT signing secret key
JWT_SECRET=your_jwt_secure_secret_key_here

# Frontend Client URL for CORS policy
# In production, set this to your Vercel deployment URL, e.g. https://sportnest-client.vercel.app
CLIENT_URL=http://localhost:5173

# Environment (development or production)
NODE_ENV=development

# Google OAuth Client ID (must match VITE_GOOGLE_CLIENT_ID exactly)
GOOGLE_CLIENT_ID=540753764694-0kr8id5kksurdf4t3n76bg5q197t8h54.apps.googleusercontent.com
